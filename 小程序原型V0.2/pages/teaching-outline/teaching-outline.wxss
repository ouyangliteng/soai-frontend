.textarea {
  width: 100%;
  min-height: 170rpx;
  box-sizing: border-box;
  margin-top: 18rpx;
  padding: 20rpx;
  border: 1rpx solid #d9e0ea;
  border-radius: 14rpx;
  background: #ffffff;
  font-size: 27rpx;
  line-height: 1.5;
}

.textarea-small {
  min-height: 118rpx;
}

.caution {
  padding: 16rpx;
  border-radius: 12rpx;
  background: #fff4e5;
  color: #b54708;
}

.week-card {
  margin-bottom: 22rpx;
}

.week-card .tag {
  max-width: 300rpx;
  justify-content: center;
}

.sub-title {
  margin-top: 24rpx;
  margin-bottom: 10rpx;
  color: #111827;
  font-size: 26rpx;
  font-weight: 700;
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 14rpx;
}
