<view class="page">
  <view class="hero" wx:if="{{role === 'student'}}">
    <view class="hero-title">学员资料</view>
    <view class="hero-subtitle">资料用于辅助 AI 判断训练背景，报告会保留生成当时的资料快照。</view>
  </view>

  <view class="hero" wx:else>
    <view class="hero-title">教练资料</view>
    <view class="hero-subtitle">教练端资料只显示教练基本信息，学员训练资料在教练工作台查看。</view>
  </view>

  <view class="card" wx:if="{{role === 'coach'}}">
    <view class="coach-profile-row">
      <view class="coach-avatar">{{coach.name ? coach.name.slice(0, 1) : '教'}}</view>
      <view style="flex: 1;">
        <view class="card-title">{{coach.name || '教练账号'}}</view>
        <view class="muted" style="margin-top: 8rpx;">{{coach.clubName || '未绑定俱乐部'}}</view>
      </view>
      <view class="tag">{{coach.verified ? '已认证' : '待认证'}}</view>
    </view>
    <view class="divider"></view>
    <view class="score-row">
      <view>登录方式</view>
      <view>{{coach.loginType === 'company_wechat' ? '公司微信号' : '教练个人微信'}}</view>
    </view>
    <view class="score-row">
      <view>模拟微信 ID</view>
      <view>{{coach.wxOpenId}}</view>
    </view>
    <view class="score-row">
      <view>联系电话</view>
      <view>{{coach.phone || '未填写'}}</view>
    </view>
    <view class="divider"></view>
    <view class="field">
      <view class="field-label">所属俱乐部</view>
      <input class="input" value="{{coachForm.clubName}}" data-field="clubName" bindinput="onCoachInput" placeholder="请输入教练所属俱乐部" />
    </view>
    <view class="field">
      <view class="field-label">联系电话</view>
      <input class="input" value="{{coachForm.phone}}" data-field="phone" bindinput="onCoachInput" placeholder="请输入联系电话" />
    </view>
    <view class="muted" style="margin-top: 18rpx;">保存后，学员绑定教练时会看到新的俱乐部信息；已绑定该教练的学员资料也会同步更新。</view>
    <view class="btn btn-primary" style="margin-top: 24rpx;" bindtap="saveCoach">保存教练资料</view>
  </view>

  <view class="card" wx:if="{{role === 'student'}}">
    <view class="row">
      <view>
        <view class="card-title">数据源</view>
        <view class="muted">当前：{{dataMode === 'api' ? 'Mock API 联调' : '本地演示'}}</view>
      </view>
      <view class="tag">{{dataMode}}</view>
    </view>
    <view class="row" style="margin-top: 22rpx;">
      <view class="btn {{dataMode === 'local' ? 'btn-primary' : 'btn-ghost'}}" style="flex: 1;" data-mode="local" bindtap="switchDataMode">本地</view>
      <view class="btn {{dataMode === 'api' ? 'btn-primary' : 'btn-ghost'}}" style="flex: 1;" data-mode="api" bindtap="switchDataMode">API</view>
    </view>
    <view class="divider"></view>

    <view class="avatar-row">
      <image class="avatar" wx:if="{{form.avatarUrl}}" src="{{form.avatarUrl}}" mode="aspectFill"></image>
      <view class="avatar avatar-empty" wx:else>{{form.name ? form.name.slice(0, 1) : '学'}}</view>
      <view style="flex: 1;">
        <view class="card-title">学员头像</view>
        <view class="muted" style="margin-top: 8rpx;">头像会同步到学员首页和教练端学员资料。</view>
      </view>
      <view class="btn btn-secondary avatar-btn" bindtap="chooseAvatar">设置头像</view>
    </view>
    <view class="divider"></view>

    <view class="field">
      <view class="field-label">姓名</view>
      <input class="input" value="{{form.name}}" data-field="name" bindinput="onInput" placeholder="请输入学员姓名" />
    </view>
    <view class="field">
      <view class="field-label">年龄</view>
      <input class="input" type="number" value="{{form.age}}" data-field="age" bindinput="onInput" placeholder="请输入年龄" />
    </view>
    <view class="field">
      <view class="field-label">身高 cm</view>
      <input class="input" type="number" value="{{form.heightCm}}" data-field="heightCm" bindinput="onInput" placeholder="请输入身高" />
    </view>
    <view class="field">
      <view class="field-label">体重 kg</view>
      <input class="input" type="number" value="{{form.weightKg}}" data-field="weightKg" bindinput="onInput" placeholder="请输入体重" />
    </view>
    <view class="field">
      <view class="field-label">骑龄 年</view>
      <input class="input" type="number" value="{{form.ridingYears}}" data-field="ridingYears" bindinput="onInput" placeholder="请输入骑龄" />
    </view>
    <view class="field">
      <view class="field-label">当前等级</view>
      <input class="input" value="{{form.currentLevel}}" data-field="currentLevel" bindinput="onInput" placeholder="如：初级进阶" />
    </view>
    <view class="field">
      <view class="field-label">绑定教练</view>
      <picker mode="selector" range="{{coachNames}}" value="{{selectedCoachIndex}}" bindchange="onCoachPicker">
        <view class="picker-box">{{coachNames[selectedCoachIndex] || '请选择教练'}}</view>
      </picker>
    </view>
    <view class="field">
      <view class="field-label">所属俱乐部</view>
      <input class="input" value="{{form.clubName}}" data-field="clubName" bindinput="onInput" placeholder="请输入俱乐部" />
    </view>
  </view>

  <view class="btn btn-primary" style="margin-top: 28rpx;" bindtap="save" wx:if="{{role === 'student'}}">保存资料</view>
  <view class="muted" style="margin-top: 18rpx;" wx:if="{{role === 'student'}}">姓名、骑龄、当前等级是上传训练视频前的重点字段。</view>
</view>
