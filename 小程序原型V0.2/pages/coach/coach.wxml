<view class="page">
  <view class="hero feed-hero">
    <view>
      <view class="hero-title">SOAI 首页</view>
      <view class="hero-subtitle">赛事动态、业内新闻和训练科技观察，按微博信息流形式持续更新。</view>
    </view>
    <view class="feed-role">{{role === 'coach' ? '教练端' : '学员端'}}</view>
  </view>

  <view class="quick-actions">
    <view class="quick-action" bindtap="goTraining">
      <view class="quick-title">进入训练</view>
      <view class="quick-subtitle">{{role === 'coach' ? '学员报告与训练计划' : '上传视频与查看成绩'}}</view>
    </view>
    <view class="quick-action" bindtap="goEvents">
      <view class="quick-title">赛事入口</view>
      <view class="quick-subtitle">赛事筛选与安排</view>
    </view>
  </view>

  <view class="feed-tabs">
    <view
      class="feed-tab {{filter === item.key ? 'active' : ''}}"
      wx:for="{{filterTabs}}"
      wx:key="key"
      data-filter="{{item.key}}"
      bindtap="changeFilter"
    >{{item.label}}</view>
  </view>

  <view class="feed-toolbar">
    <view class="muted">信息流模拟抓取源：赛事日历、行业观察、教学科技动态</view>
    <view class="refresh-btn" bindtap="refreshFeed">刷新</view>
  </view>

  <view class="feed-card" wx:for="{{visibleFeed}}" wx:key="id">
    <view class="feed-head">
      <view class="source-avatar">{{item.sourceInitial}}</view>
      <view style="flex: 1;">
        <view class="source-name">{{item.source}}</view>
        <view class="feed-time">{{item.timeText}} · {{item.type}}</view>
      </view>
      <view class="feed-type {{item.type === '赛事' ? 'event' : 'news'}}">{{item.type}}</view>
    </view>

    <view class="feed-title">{{item.title}}</view>
    <view class="feed-summary">{{item.summary}}</view>

    <view class="feed-tags">
      <view class="feed-tag" wx:for="{{item.tags}}" wx:for-item="tag" wx:key="*this">#{{tag}}</view>
    </view>

    <view class="feed-actions">
      <view>转发 {{item.stats.repost}}</view>
      <view>评论 {{item.stats.comment}}</view>
      <view>点赞 {{item.stats.like}}</view>
    </view>
  </view>
</view>
