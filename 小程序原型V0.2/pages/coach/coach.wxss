.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx;
  margin-top: 24rpx;
}

.stat-card {
  padding: 26rpx;
  border: 1rpx solid #e6ebf2;
  border-radius: 16rpx;
  background: #ffffff;
}

.stat-value {
  color: #0f67ff;
  font-size: 44rpx;
  font-weight: 800;
}

.stat-label {
  margin-top: 8rpx;
  color: #667085;
  font-size: 24rpx;
}

.score-pill {
  min-width: 70rpx;
  text-align: right;
  color: #0f67ff;
  font-size: 38rpx;
  font-weight: 800;
}

