.feed-hero {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.feed-role {
  flex: 0 0 auto;
  padding: 8rpx 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.24);
  border-radius: 999rpx;
  color: rgba(255, 255, 255, 0.86);
  font-size: 22rpx;
  font-weight: 700;
}

.quick-actions {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx;
  margin-top: 22rpx;
}

.quick-action {
  padding: 24rpx;
  border: 1rpx solid #e6ebf2;
  border-radius: 16rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 28rpx rgba(15, 23, 42, 0.05);
}

.quick-title {
  color: #111827;
  font-size: 29rpx;
  font-weight: 800;
}

.quick-subtitle {
  margin-top: 10rpx;
  color: #667085;
  font-size: 23rpx;
  line-height: 1.45;
}

.feed-tabs {
  display: flex;
  gap: 14rpx;
  margin-top: 28rpx;
  padding: 8rpx;
  border-radius: 999rpx;
  background: #e9eef6;
}

.feed-tab {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 64rpx;
  border-radius: 999rpx;
  color: #344054;
  font-size: 25rpx;
  font-weight: 800;
}

.feed-tab.active {
  color: #ffffff;
  background: #111827;
}

.feed-toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 22rpx;
}

.feed-toolbar .muted {
  flex: 1;
}

.refresh-btn {
  flex: 0 0 auto;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  color: #0f67ff;
  background: #edf4ff;
  font-size: 23rpx;
  font-weight: 800;
}

.feed-card {
  margin-top: 20rpx;
  padding: 28rpx;
  border: 1rpx solid #e6ebf2;
  border-radius: 16rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 28rpx rgba(15, 23, 42, 0.05);
}

.feed-head {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.source-avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
  flex: 0 0 72rpx;
  border-radius: 999rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #111827, #0f67ff);
  font-size: 28rpx;
  font-weight: 900;
}

.source-name {
  color: #111827;
  font-size: 27rpx;
  font-weight: 800;
}

.feed-time {
  margin-top: 6rpx;
  color: #667085;
  font-size: 22rpx;
}

.feed-type {
  flex: 0 0 auto;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 800;
}

.feed-type.event {
  color: #0f67ff;
  background: #edf4ff;
}

.feed-type.news {
  color: #047857;
  background: #e8f8f2;
}

.feed-title {
  margin-top: 24rpx;
  color: #111827;
  font-size: 32rpx;
  line-height: 1.35;
  font-weight: 900;
}

.feed-summary {
  margin-top: 14rpx;
  color: #344054;
  font-size: 26rpx;
  line-height: 1.58;
}

.feed-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 20rpx;
}

.feed-tag {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  color: #0f67ff;
  background: #f3f7ff;
  font-size: 22rpx;
  font-weight: 700;
}

.feed-actions {
  display: flex;
  justify-content: space-around;
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #edf0f5;
  color: #667085;
  font-size: 23rpx;
  font-weight: 700;
}
