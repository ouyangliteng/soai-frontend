.consent-row {
  display: grid;
  grid-template-columns: 48rpx 1fr;
  gap: 18rpx;
  align-items: start;
}

.checkbox {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 44rpx;
  height: 44rpx;
  border: 2rpx solid #c8d2df;
  border-radius: 12rpx;
  color: #ffffff;
  background: #ffffff;
  font-size: 24rpx;
  font-weight: 800;
}

.checkbox.checked {
  border-color: #0f67ff;
  background: #0f67ff;
}
