.score-row {
  display: flex;
  justify-content: space-between;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #edf0f5;
  color: #344054;
  font-size: 27rpx;
}

.score-row:last-child {
  border-bottom: 0;
}

.textarea {
  width: 100%;
  min-height: 150rpx;
  box-sizing: border-box;
  margin-top: 22rpx;
  padding: 20rpx;
  border: 1rpx solid #d9e0ea;
  border-radius: 14rpx;
  background: #ffffff;
  font-size: 27rpx;
}

.product-card .tag {
  max-width: 180rpx;
  justify-content: center;
}

.knowledge-list {
  display: grid;
  gap: 12rpx;
  margin-top: 18rpx;
}

.knowledge-list view {
  position: relative;
  padding-left: 22rpx;
  color: #344054;
  font-size: 25rpx;
  line-height: 1.55;
}

.knowledge-list view::before {
  content: "";
  position: absolute;
  left: 0;
  top: 16rpx;
  width: 8rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: #0f67ff;
}

.caution {
  margin-top: 18rpx;
  padding: 16rpx;
  border-radius: 12rpx;
  background: #fff4e5;
  color: #b54708;
}
