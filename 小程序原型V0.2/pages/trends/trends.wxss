.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx;
  margin-top: 24rpx;
}

.stat-card {
  padding: 26rpx;
  border: 1rpx solid #e6ebf2;
  border-radius: 16rpx;
  background: #ffffff;
}

.stat-value {
  color: #0f67ff;
  font-size: 44rpx;
  font-weight: 800;
}

.stat-label {
  margin-top: 8rpx;
  color: #667085;
  font-size: 24rpx;
}

.event-card {
  overflow: hidden;
}

.event-progress {
  width: 100%;
  height: 14rpx;
  margin-top: 24rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: #e9eef6;
}

.event-progress-bar {
  max-width: 100%;
  height: 14rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #11c4b5, #0f67ff);
}

.event-meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.mini-tag {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  color: #344054;
  background: #f3f6fb;
  font-size: 22rpx;
  font-weight: 700;
}

.trend-chart {
  display: flex;
  align-items: flex-end;
  gap: 18rpx;
  min-height: 190rpx;
  margin-top: 28rpx;
  padding: 18rpx;
  border-radius: 14rpx;
  background: #f6f8fc;
}

.trend-column {
  flex: 1;
  text-align: center;
}

.trend-bar {
  min-height: 46rpx;
  border-radius: 12rpx 12rpx 4rpx 4rpx;
  background: linear-gradient(180deg, #28c2ff 0%, #0f67ff 100%);
}

.trend-score {
  margin-top: 10rpx;
  color: #111827;
  font-size: 23rpx;
  font-weight: 700;
}

.trend-date {
  margin-top: 6rpx;
  color: #667085;
  font-size: 21rpx;
}

.metric {
  margin-top: 16rpx;
  color: #344054;
  font-size: 26rpx;
}
