.caution {
  padding: 16rpx;
  border-radius: 12rpx;
  background: #fff4e5;
  color: #b54708;
}

.week-card {
  margin-bottom: 22rpx;
}

.week-card .tag {
  max-width: 300rpx;
  justify-content: center;
}

.sub-title {
  margin-top: 24rpx;
  margin-bottom: 10rpx;
  color: #111827;
  font-size: 26rpx;
  font-weight: 700;
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 14rpx;
}

.export-canvas {
  position: fixed;
  left: -9999rpx;
  top: -9999rpx;
  width: 680px;
  height: 980px;
}
