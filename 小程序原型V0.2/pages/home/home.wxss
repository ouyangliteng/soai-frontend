.profile-left {
  flex: 0 0 auto;
}

.home-avatar {
  width: 92rpx;
  height: 92rpx;
  min-width: 92rpx;
  max-width: 92rpx;
  border-radius: 999rpx;
  background: #edf4ff;
}

.avatar-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #0f67ff;
  font-size: 36rpx;
  font-weight: 800;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx;
  margin-top: 24rpx;
}

.stat-card {
  padding: 26rpx;
  border: 1rpx solid #e6ebf2;
  border-radius: 16rpx;
  background: #ffffff;
}

.stat-value {
  color: #0f67ff;
  font-size: 44rpx;
  font-weight: 800;
}

.stat-label {
  margin-top: 8rpx;
  color: #667085;
  font-size: 24rpx;
}

.student-meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.mini-tag {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  color: #344054;
  background: #f3f6fb;
  font-size: 22rpx;
  font-weight: 700;
}

.mini-chart {
  display: flex;
  align-items: flex-end;
  gap: 18rpx;
  height: 140rpx;
  margin-top: 26rpx;
  padding: 18rpx;
  border-radius: 14rpx;
  background: #f6f8fc;
}

.chart-bar {
  position: relative;
  flex: 1;
  min-height: 48rpx;
  border-radius: 10rpx 10rpx 4rpx 4rpx;
  background: linear-gradient(180deg, #28c2ff 0%, #0f67ff 100%);
}

.chart-bar text {
  position: absolute;
  top: -34rpx;
  left: 0;
  right: 0;
  text-align: center;
  color: #344054;
  font-size: 21rpx;
}
