.student-chart {
  display: flex;
  align-items: flex-end;
  gap: 18rpx;
  min-height: 180rpx;
  padding: 18rpx;
  border-radius: 14rpx;
  background: #f6f8fc;
}

.student-column {
  flex: 1;
  text-align: center;
}

.student-bar {
  min-height: 46rpx;
  border-radius: 12rpx 12rpx 4rpx 4rpx;
  background: linear-gradient(180deg, #28c2ff 0%, #0f67ff 100%);
}

.student-score {
  margin-top: 10rpx;
  color: #111827;
  font-size: 23rpx;
  font-weight: 700;
}

