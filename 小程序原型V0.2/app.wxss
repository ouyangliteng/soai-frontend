page {
  min-height: 100%;
  background: #f5f7fb;
  color: #101828;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", Arial, sans-serif;
}

.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 28rpx 28rpx 56rpx;
}

.hero {
  padding: 34rpx 30rpx;
  border-radius: 18rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #08111f 0%, #12335d 58%, #0f67ff 100%);
  box-shadow: 0 18rpx 40rpx rgba(8, 17, 31, 0.16);
}

.hero-title {
  font-size: 42rpx;
  font-weight: 700;
  line-height: 1.2;
}

.hero-subtitle {
  margin-top: 12rpx;
  color: rgba(255, 255, 255, 0.76);
  font-size: 25rpx;
  line-height: 1.5;
}

.section-title {
  margin: 34rpx 0 18rpx;
  font-size: 31rpx;
  font-weight: 700;
  color: #111827;
}

.card {
  margin-top: 20rpx;
  padding: 28rpx;
  border: 1rpx solid #e6ebf2;
  border-radius: 16rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 28rpx rgba(15, 23, 42, 0.05);
}

.card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #111827;
}

.muted {
  color: #667085;
  font-size: 25rpx;
  line-height: 1.5;
}

.small {
  color: #667085;
  font-size: 23rpx;
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: 14rpx;
  font-size: 29rpx;
  font-weight: 700;
}

.btn-primary {
  color: #ffffff;
  background: #0f67ff;
}

.btn-secondary {
  color: #0f67ff;
  background: #edf4ff;
}

.btn-ghost {
  color: #344054;
  background: #f3f6fb;
}

.tag {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  color: #0f67ff;
  background: #edf4ff;
  font-size: 22rpx;
  font-weight: 600;
}

.tag-warning {
  color: #b54708;
  background: #fff4e5;
}

.divider {
  height: 1rpx;
  margin: 24rpx 0;
  background: #edf0f5;
}

.field {
  margin-top: 22rpx;
}

.field-label {
  margin-bottom: 10rpx;
  color: #344054;
  font-size: 25rpx;
  font-weight: 600;
}

.input {
  height: 84rpx;
  box-sizing: border-box;
  padding: 0 22rpx;
  border: 1rpx solid #d9e0ea;
  border-radius: 14rpx;
  background: #ffffff;
  color: #111827;
  font-size: 28rpx;
}

.list-item {
  padding: 22rpx 0;
  border-bottom: 1rpx solid #edf0f5;
}

.list-item:last-child {
  border-bottom: 0;
}

.progress-track {
  width: 100%;
  height: 14rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: #e9eef6;
}

.progress-bar {
  height: 14rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #0f67ff, #28c2ff);
}

