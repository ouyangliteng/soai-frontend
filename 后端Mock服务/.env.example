# SOAI API production MVP example.
# Copy to your server environment manager or PM2 env block. Do not commit real secrets.

NODE_ENV=production
PORT=8787

SOAI_API_PUBLIC_BASE_URL=https://api.soai.yun
SOAI_ADMIN_TOKEN=replace-with-strong-admin-token

# MVP persistence. Use JSON for small closed beta only; migrate to MySQL/PostgreSQL before public scale.
SOAI_DB_FILE=/data/soai-storage/db/soai-db.json

# Local storage mode. Recommended for first server smoke test.
SOAI_STORAGE_PROVIDER=local
SOAI_STORAGE_ROOT=/data/soai-storage
SOAI_STORAGE_PUBLIC_BASE_URL=https://api.soai.yun/storage
SOAI_MAX_UPLOAD_MB=150
SOAI_MAX_VIDEO_DURATION_SEC=15

# Switch to aliyun-oss after API + ffmpeg + pose pipeline is healthy.
# SOAI_STORAGE_PROVIDER=aliyun-oss
# ALIYUN_OSS_BUCKET=soai-your-bucket
# ALIYUN_OSS_REGION=oss-cn-hangzhou
# ALIYUN_OSS_ENDPOINT=https://soai-your-bucket.oss-cn-hangzhou.aliyuncs.com
# ALIYUN_OSS_PUBLIC_BASE_URL=https://soai-your-bucket.oss-cn-hangzhou.aliyuncs.com
# ALIYUN_ACCESS_KEY_ID=replace-with-ram-access-key-id
# ALIYUN_ACCESS_KEY_SECRET=replace-with-ram-access-key-secret
# ALIYUN_RAM_ROLE_ARN=
# ALIYUN_OSS_UPLOAD_EXPIRES_SEC=900

# Frame extraction and pose service.
SOAI_FRAME_FPS=0.25
SOAI_POSE_PROVIDER=http
SOAI_POSE_SERVICE_URL=http://127.0.0.1:8793
SOAI_POSE_MODEL_PROVIDER=yolo-pose
SOAI_POSE_SERVICE_TIMEOUT_MS=180000
SOAI_REQUIRE_REAL_POSE=true
SOAI_POSE_ALLOW_SYNTHETIC_FALLBACK=false
