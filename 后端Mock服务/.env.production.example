NODE_ENV=production
PORT=8787

# Public API domain used to generate upload URLs for the WeChat mini program.
SOAI_API_PUBLIC_BASE_URL=https://api.soai.yun

# First production test uses local disk storage behind Nginx.
# Replace this with COS/OSS after stable mini-program testing.
SOAI_STORAGE_PROVIDER=local
SOAI_STORAGE_ROOT=/data/soai-storage
SOAI_STORAGE_PUBLIC_BASE_URL=https://api.soai.yun/storage
SOAI_DB_FILE=/data/soai-storage/db/soai-db.json

# Frame extraction and pose provider.
SOAI_FRAME_FPS=4
SOAI_POSE_PROVIDER=synthetic
